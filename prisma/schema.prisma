generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. GLOBAL IDENTITY
model User {
  id                String   @id @default(uuid())
  email             String   @unique
  persona           String   @default("quant") // Global theme/persona
  globalStreak      Int      @default(0)
  totalPoints       Int      @default(0)
  onboarded         Boolean  @default(false)
  username          String?  @unique
  displayName       String?
  lastSessionDate   DateTime?
  streakFreezes     Int      @default(0)
  averageVelocityMs Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Back-relations for Prisma
  settings          UserSettings?
  badges            UserBadge[]
  activities        UserActivity[]
  
  // New back-relations
  bootcampDays      BootcampDay[]
  cardProgress      UserCardProgress[]
  reviewLogs        ReviewLog[]
}

model UserSettings {
  id                String  @id @default(uuid())
  userId            String  @unique
  commutativity     Boolean @default(true)
  dailyGoal         Int     @default(50)
  soundEnabled      Boolean @default(true)
  hapticEnabled     Boolean @default(true)
  leetcodeUsername  String? // Added for tracking DSA progress
  
  user              User    @relation(fields: [userId], references: [id])
}

model Badge {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  condition   String
  
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])
  
  @@unique([userId, badgeId])
}

model UserActivity {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime
  count     Int      @default(1)
  
  user      User     @relation(fields: [userId], references: [id])
  
  @@unique([userId, date])
}

// Removed old Reflex tables
// ---------------------------------------------------------------------------
// NEW UNIFIED 3NF ARCHITECTURE
// ---------------------------------------------------------------------------

// 1. BOOTCAMP TRACKING
model BootcampDay {
  id          String   @id @default(uuid())
  userId      String
  dayNumber   Int
  date        DateTime?
  status      String   @default("locked") // locked, in_progress, completed
  createdAt   DateTime @default(now())
  
  tasks       BootcampTask[]
  user        User     @relation(fields: [userId], references: [id])
  
  @@unique([userId, dayNumber])
}

model BootcampTask {
  id            String   @id @default(uuid())
  bootcampDayId String
  type          String   // dsa, math, theory, project, system_design
  title         String
  status        String   @default("pending") // pending, completed
  details       Json?    // Stores prompt data, leetcode links, etc.
  
  day           BootcampDay @relation(fields: [bootcampDayId], references: [id], onDelete: Cascade)
}

// 2. UNIFIED KNOWLEDGE ENGINE
model Deck {
  id          String   @id @default(uuid())
  slug        String   @unique // e.g. "math-addition", "cpp-pointers", "brainteasers"
  name        String
  type        String   // math, theory, brainteaser
  
  cards       Card[]
}

model Card {
  id          String   @id @default(uuid())
  deckId      String
  front       String   // Question or prompt
  back        String   // Answer
  category    String?  // Sub-tag
  difficulty  Int      // Relative difficulty scale
  
  deck        Deck     @relation(fields: [deckId], references: [id])
  progress    UserCardProgress[]
}

model UserCardProgress {
  id              String   @id @default(uuid())
  userId          String
  cardId          String
  
  ef              Float    @default(2.5)
  interval        Int      @default(0)
  consecutiveHit  Int      @default(0)
  nextReview      DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id])
  card            Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
}

model ReviewLog {
  id          String   @id @default(uuid())
  userId      String
  cardId      String
  timeMs      Int      
  quality     Int      
  sessionMode String   @default("review") // review, learn, sudden_death
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])
}
