generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. GLOBAL IDENTITY
model User {
  id                String   @id @default(uuid())
  email             String   @unique
  persona           String   @default("quant") // Global theme/persona
  globalStreak      Int      @default(0)
  totalPoints       Int      @default(0)
  onboarded         Boolean  @default(false)
  displayName       String?
  lastSessionDate   DateTime?
  streakFreezes     Int      @default(0)
  averageVelocityMs Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Back-relations for Prisma
  reflexProfile     ReflexProfile?
  settings          UserSettings?
  badges            UserBadge[]
  diagnosticResults DiagnosticResult[]
}

model UserSettings {
  id                String  @id @default(uuid())
  userId            String  @unique
  commutativity     Boolean @default(true)
  dailyGoal         Int     @default(50)
  soundEnabled      Boolean @default(true)
  hapticEnabled     Boolean @default(true)
  
  user              User    @relation(fields: [userId], references: [id])
}

model Badge {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  condition   String
  
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])
  
  @@unique([userId, badgeId])
}

// 2. MODULE: REFLEX ENGINE
// All settings specific to the Reflex module live here, keeping User clean.
model ReflexProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  horizon              String   @default("30_days") // Reflex-specific setting
  moduleStreak         Int      @default(0)         // Streak just for this module
  suddenDeathHighScore Int      @default(0)
  
  user              User                 @relation(fields: [userId], references: [id])
  progress          UserReflexProgress[]
  velocityLogs      ReflexVelocityLogs[]
}

model ReflexCard {
  id          String   @id @default(uuid())
  question    String   
  answer      String   
  category    String   
  difficulty  Int      
  progress    UserReflexProgress[]
}

model UserReflexProgress {
  id              String   @id @default(uuid())
  reflexProfileId String
  cardId          String
  ef              Float    @default(2.5)
  interval        Int      @default(0)
  consecutiveHit  Int      @default(0)
  nextReview      DateTime @default(now())
  
  profile         ReflexProfile @relation(fields: [reflexProfileId], references: [id])
  card            ReflexCard    @relation(fields: [cardId], references: [id])

  @@unique([reflexProfileId, cardId])
}

model ReflexVelocityLogs {
  id              String   @id @default(uuid())
  reflexProfileId String
  cardId          String
  timeMs          Int      
  quality         Int      
  sessionMode     String   @default("review") // review, learn, sudden_death
  createdAt       DateTime @default(now())

  profile         ReflexProfile @relation(fields: [reflexProfileId], references: [id])
}

model DiagnosticResult {
  id                   String   @id @default(uuid())
  userId               String
  score                Int      
  maxDifficultyReached Int      
  averageVelocityMs    Float    
  accuracy             Float    
  category             String   @default("multiplication")
  createdAt            DateTime @default(now())

  user                 User     @relation(fields: [userId], references: [id])
}
